# Udev rules for Wondom GAB8 USB audio devices
# Assigns persistent ALSA card names based on USB path
#
# Install: sudo cp 99-wondom-gab8.rules /etc/udev/rules.d/
# Reload:  sudo udevadm control --reload-rules && sudo udevadm trigger
#
# IMPORTANT: Label your physical USB ports and always plug each amp
# into the same port. The paths below correspond to (verified 2026-06-10):
#   amp1 = USB controller 1, port 2     (xhci-hcd.1-usb-0:2:1.1)  [NEW cased unit, 2026-06-15]
#   amp2 = USB controller 0, port 2     (xhci-hcd.0-usb-0:2:1.1)  [2nd unit, 2026-06-17]
#   amp3 = USB controller 1, port 1     (xhci-hcd.1-usb-0:1:1.1)
#   amp4 = C-Media line-in, ctrl 1 1.4  (xhci-hcd.1-usb-0:1.4:1.0)

# GAB8 -> amp1 (NEW cased unit, direct on ctrl 1 port 2; re-mapped 2026-06-15)
SUBSYSTEM=="sound", ATTR{id}=="GAB8*", ENV{ID_PATH}=="platform-xhci-hcd.1-usb-0:2:1.1", ATTR{id}="amp1"

# GAB8 -> amp2 (2nd unit, ctrl 0 port 2; mapped 2026-06-17)
SUBSYSTEM=="sound", ATTR{id}=="GAB8*", ENV{ID_PATH}=="platform-xhci-hcd.0-usb-0:2:1.1", ATTR{id}="amp2"

# GAB8 -> amp3 (re-identified 2026-06-10)
SUBSYSTEM=="sound", ATTR{id}=="GAB8*", ENV{ID_PATH}=="platform-xhci-hcd.0-usb-0:1:1.1", ATTR{id}="amp3"

# C-Media USB Advanced Audio Device (2ch), controller 1, port 1.4 -> amp4
# Not a GAB8 — enumerates with the generic id "Device", so match by USB path.
SUBSYSTEM=="sound", ATTR{id}=="Device", ENV{ID_PATH}=="platform-xhci-hcd.1-usb-0:1.4:1.0", ATTR{id}="amp4"
